  #ai-blob-bubble.visible { opacity: 1; transform: translateY(0) scale(1); }

  /* Panel content (dark, Apple-Intelligence-like, translucent glass) */
  #ai-panel-content {
    position: absolute; inset: 0;
    border-radius: inherit;
    background: radial-gradient(120% 140% at 20% 0%, rgba(20,28,60,0.72) 0%, rgba(4,6,15,0.82) 55%);
    backdrop-filter: blur(36px) saturate(180%);
    -webkit-backdrop-filter: blur(36px) saturate(180%);
    opacity: 0;
    transform: scale(0.98);
