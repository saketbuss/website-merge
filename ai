       ============================================================ */
    responses: [
      // Account & access
      { keywords: ["forgot password", "reset password", "can't log in", "cant log in", "login issue"], reply: "Go to Account → Security → \"Reset password.\" You'll get a reset link within a couple minutes — check spam if it's slow." },
