  #ai-blob-root.expanded #ai-blob-canvas { opacity: 0; pointer-events: none; }

  /* Speech bubble hint */
  #ai-blob-bubble {
    position: fixed;
    max-width: 220px;
    padding: 10px 14px;
    font-size: 13px;
    line-height: 1.4;
    color: #26262b;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
