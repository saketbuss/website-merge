  #ai-blob-root.expanded #ai-panel-content { opacity: 1; transform: scale(1); pointer-events: auto; }

  #ai-panel-content::before {
    content: "";
    position: absolute; inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: conic-gradient(from 0deg, var(--accent-1), var(--accent-2), var(--accent-3), var(--accent-4), var(--accent-1));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
