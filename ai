  #ai-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 18px 14px;
    flex-shrink: 0;
  }
  #ai-panel-title { display: flex; align-items: center; gap: 10px; }
  #ai-panel-title-dot {
