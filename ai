      { keywords: ["lag", "ping", "latency", "fps", "frame rate", "stutter"], reply: "For performance issues: lower in-game graphics preset first, then check Settings → Network for the closest server region." },
      { keywords: ["patch", "update", "changelog", "patch notes"], reply: "Patch notes are posted under News → Updates each time a title ships a new build." },

      // Tournaments & multiplayer
      { keywords: ["tournament", "esport", "compete", "register a team", "team registration"], reply: "Ranked tournaments run every season. Register a team from the Tournaments tab — you'll need at least 3 verified members." },
      { keywords: ["rank", "ranked", "matchmaking", "mmr", "elo"], reply: "Matchmaking pairs you by recent rank plus performance in your last 10 matches, so it adjusts fast if you're on a streak." },
      { keywords: ["multiplayer", "co-op", "coop", "party", "invite friend"], reply: "You can party up from a friend's profile card or invite by username in-game. Cross-platform play is on by default." },

      // Store & payments
      { keywords: ["price", "pricing", "cost", "subscription", "plan"], reply: "Most titles are pay-once; a few live-service games offer an optional monthly pass. Check the Store section for exact pricing per title." },
      { keywords: ["refund"], reply: "Refunds are available within 14 days of purchase if you've played under 2 hours — request one from Store → Order History." },
      { keywords: ["payment", "card", "paypal", "billing"], reply: "We accept major cards, PayPal, and regional wallets. Payment methods live under Account → Billing." },
      { keywords: ["discount", "sale", "coupon", "promo"], reply: "Seasonal sales show up on the Store homepage — worth checking back around major holidays." },

      // General / library
      { keywords: ["library", "game list", "genre", "recommend a game", "recommend"], reply: "The library spans shooters, RPGs, strategy, and cozy sims — filter by genre from the Library tab, or tell me a genre and I'll point you to a category." },
      { keywords: ["hi", "hello", "hey"], reply: "Hey! What can I help you find — games, tournaments, or account stuff?" },
      { keywords: ["who are you", "what are you", "your name"], reply: "I'm Nova — a lightweight assistant built into this page. I run fully offline, right in your browser." },
      { keywords: ["thanks", "thank you"], reply: "Anytime. GG — let me know if anything else comes up." },
      { keywords: ["bye", "goodbye"], reply: "See you on the ladder — I'll be floating around if you need me." }
    ],
    fallback: "I don't have that one in my knowledge base yet, but I can help with games, downloads, tournaments, ranks, or your account — try rephrasing?"
  };

  /* ============================================================
     STYLES
     ============================================================ */
  const style = document.createElement("style");
  style.textContent = `
