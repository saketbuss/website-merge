    font-size: clamp(2.2rem, 5vw, 3.6rem);
    letter-spacing: -0.03em;
    margin: 0 0 18px;
    font-weight: 650;
  }
  section p {
    max-width: 560px;
    font-size: 1.08rem;
    line-height: 1.6;
    color: #52525b;
  }
  .eyebrow {
    text-transform: uppercase;
